# Copy this file to .env (in this reasoning-engine/ directory) and fill in
# your OpenAI key below. Nothing here is required to run with
# LLM_PROVIDER=fake -- that path costs $0 and needs no key at all, see
# app/services/fake_llm_fixtures.py.

# "openai" (default, and the provider this project has actually been tested
# against) or "anthropic" or "fake"
LLM_PROVIDER=openai

# Required for the default provider (LLM_PROVIDER=openai) -- this is the key
# that matters for real responses.
OPENAI_API_KEY=

# Only needed if you switch LLM_PROVIDER to anthropic instead
ANTHROPIC_API_KEY=

# Optional: override the default model for the chosen provider
# REASONING_ENGINE_MODEL=gpt-4o-mini

# Optional: only set this to 1 if you hit "Basic Constraints of CA cert not
# marked critical" -- a local TLS-interception issue (corporate proxy, or
# antivirus "HTTPS scanning" like Norton's Web/Mail Shield), not something
# to enable by default. See app/services/llm_client.py for details.
# RELAX_TLS_STRICT_X509=1
