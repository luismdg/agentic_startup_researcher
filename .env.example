# Copy this file to .env and fill in your key. Nothing here is required —
# the pipeline runs fully in mock mode without it (GitHub/arXiv/Reddit still
# use their free, keyless real APIs regardless).

# The only configurable credential: unlocks real agentic web browsing (via
# the OpenAI Responses API's hosted web-search tool) across every channel
# except the already-free GitHub/arXiv/Reddit — google, linkedin, twitter,
# youtube, producthunt, accelerators all become real research instead of
# mock lookups. See src/orchestration/.
OPENAI_API_KEY=
