# Copy this file to .env and fill in what you have. Nothing here is
# required — the pipeline runs fully in mock mode with none of these set.

# The headline key: unlocks real agentic web browsing (via the OpenAI
# Responses API's hosted web-search tool) across every channel except the
# already-free GitHub/arXiv/Reddit — google, linkedin, twitter, youtube,
# producthunt, accelerators all become real research instead of mock
# lookups. See src/orchestration/.
OPENAI_API_KEY=

# Raises GitHub's search API rate limit; unauthenticated search already works.
GITHUB_TOKEN=

# Alternate path for real Google search if you'd rather use Custom Search
# JSON API directly instead of OpenAI web browsing. Both required together.
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Alternate path for real Product Hunt search via their GraphQL API instead
# of OpenAI web browsing.
PRODUCTHUNT_TOKEN=

# Alternate path for real YouTube search via the Data API v3 instead of
# OpenAI web browsing.
YOUTUBE_API_KEY=

# When true, disables mock-data fallback everywhere: a channel with no real
# capability configured, or whose real call fails/returns nothing, then
# contributes zero candidates instead of ever substituting synthetic data.
# Recommended once you've added real keys and want to be certain every
# result is genuine. Without OPENAI_API_KEY (and/or other keys), most
# channels will return nothing at all with this on — that's expected, not
# a bug: it means no real capability was configured for them.
GENUINE_RESULTS_ONLY=false
